# Noez GRE Tunnel Setup Configuration
# Copy this file to noez_setup.env and fill in your actual values
# DO NOT commit noez_setup.env to git - it contains sensitive data!

# =============================================================================
# REQUIRED: GRE TUNNEL CONFIGURATION
# =============================================================================

# Your Noez dedicated IP (the IP you want to send emails from)
# Example: NOEZ_IP="5.230.168.0"
NOEZ_IP=""

# Your VPS/server public IP (where BillionMail is installed)
# Example: HOST_IP="85.121.241.162"
HOST_IP=""

# Noez GRE tunnel endpoint (provided by Noez in their panel)
# Example: NOEZ_GRE_REMOTE="5.230.205.35"
NOEZ_GRE_REMOTE=""

# =============================================================================
# REQUIRED: DOMAIN CONFIGURATION
# =============================================================================

# Primary domain to configure
# Example: DOMAIN="yourdomain.com"
DOMAIN=""

# All Noez IPs assigned to you (space-separated, for SPF records and auto-setup)
# This is used by the systemd service to re-add all IPs on boot
# Example: ALL_NOEZ_IPS="5.230.168.0 5.230.168.1 5.230.168.2"
ALL_NOEZ_IPS=""

# =============================================================================
# OPTIONAL: CLOUDFLARE DNS CONFIGURATION (for automatic DNS management)
# =============================================================================

# Cloudflare API Token (needs Zone:Read and DNS:Edit permissions)
# Get this from: https://dash.cloudflare.com/profile/api-tokens
CF_API_TOKEN=""

# Cloudflare Zone ID (optional - will auto-detect if empty)
CF_ZONE_ID=""

# =============================================================================
# OPTIONAL: BILLIONMAIL CONFIGURATION
# =============================================================================

# Docker container name (usually auto-detected)
# CONTAINER_NAME="billionmail-postfix-billionmail-1"

# Container network configuration (usually auto-detected)
# DOCKER_NETWORK="billionmail_network"
# DOCKER_SUBNET="172.66.2.0/24"

# =============================================================================
# OPTIONAL: GRE TUNNEL NETWORKING (usually auto-detected)
# =============================================================================

# GRE tunnel local IP (usually 192.168.31.2)
# GRE_LOCAL="192.168.31.2"

# GRE tunnel remote IP (Noez side, usually 192.168.31.1)
# GRE_REMOTE="192.168.31.1"

# =============================================================================
# OPTIONAL: BILLIONMAIL API (for domain creation via API instead of DB)
# =============================================================================

# BillionMail API URL (e.g., https://mail.yourdomain.com)
# BM_API_URL=""

# BillionMail API Token
# BM_API_TOKEN=""
